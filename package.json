{
	"name": "@kiforks/prettier-config",
	"description": "prettier shareable config",
	"version": "2.0.0",
	"scripts": {
		"update": "ncu -u && npm install",
		"format": "prettier '**/*.{ts,html,js,json,yml}' --check",
		"format:fix": "prettier '**/*.{ts,html,js,json,yml}' --write",
		"test": "node --test --test-reporter=spec",
		"test:update-snapshots": "node tests/update-snapshots.js",
		"prepare": "husky",
		"prepublishOnly": "npm run format && npm test"
	},
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"exports": "./index.js",
	"files": [
		"index.js"
	],
	"engines": {
		"node": ">=22.22.1"
	},
	"license": "MIT",
	"author": {
		"name": "Kifor Kostiantyn",
		"email": "kifor.ko@gmail.com"
	},
	"homepage": "https://github.com/kiforks/prettier-config#readme",
	"bugs": {
		"url": "https://github.com/kiforks/prettier-config/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kiforks/prettier-config.git"
	},
	"keywords": [
		"Kifor Kostiantyn",
		"code",
		"quality",
		"style",
		"lint",
		"linter",
		"prettier",
		"prettier-config",
		"prettier config",
		"validate",
		"code style",
		"strict",
		"check",
		"checker",
		"enforce",
		"hint",
		"code lint",
		"kiforko",
		"kiforks",
		"kskifor",
		"kifor"
	],
	"dependencies": {
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@prettier/plugin-oxc": "^0.1.4",
		"prettier-plugin-ember-template-tag": "^2.1.5",
		"prettier-plugin-organize-attributes": "^1.0.0"
	},
	"peerDependencies": {
		"prettier": "^3.8.0"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.2",
		"prettier": "^3.8.3"
	}
}
